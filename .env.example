OPENAI_API_KEY=
# Remote PostgreSQL URL (required)
# Example: postgresql://user:password@host/dbname?sslmode=require
POSTGRESQL_URL=

CHAT_MODEL=gpt-5.1
VISION_MODEL=gpt-5-mini
REWRITE_MODEL=gpt-5.1
EMBEDDING_MODEL=text-embedding-3-small

RETRIEVAL_K=4
HISTORY_LIMIT=12
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

UPLOADS_DIR=/app/uploads
PAGE_IMAGES_DIR=/app/page_images
QDRANT_PATH=/app/qdrant_vectordb
QDRANT_COLLECTION_NAME=multimodal_pdf_pages
